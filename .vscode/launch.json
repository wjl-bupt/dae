    "version": "0.2.0",
    "configurations": [
        {
            "name": "DAE: Atari",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/train.py",
            "console": "integratedTerminal",
            "args": [
                "--algo", "CustomPPO", 
                "--hparam_file", "/root/dae/params/CustomPPO_atari.yml", 
                "--envs", "ALE/Breakout-v5", 
                "--threads", "8"
            ]
        },

        {
            "name": "DAE: MinAtar",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/train.py",
            "console": "integratedTerminal",
            "args": [
                "--algo", "CustomPPO", 
                "--hparam_file", "/root/dae/params/CustomPPO_minatar.yml", 
                "--envs", "", 
                "--threads", "1"
            ]
        }
    ]
}