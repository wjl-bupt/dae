    "version": "0.2.0",
    "configurations": [
        {
            "name": "DAE: Atari",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/train.py",
            "console": "integratedTerminal",
            "args": [
                "--algo", "CustomPPO", 
                "--hparam_file", "/root/dae/params/CustomPPO_atari_debugger.yml", 
                "--envs", "ALE/Breakout-v5", 
                "--threads", "8"
            ]
        },
        {
            "name": "DAE: Continous Space",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/train.py",
            "console": "integratedTerminal",
            "args": [
                "--algo", "CustomPPO", 
                "--hparam_file", "${workspaceFolder}/params/CustomPPO_mujoco_debugger.yml", 
                "--envs", "Humanoid-v5", 
                "--threads", "4",
                "--continous",
                // "--use_wandb",
                // "--logging",
                // "--project", "callback-test",
                
            ]
        },

        {
            "name": "PPO: Continous Space",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/train.py",
            "console": "integratedTerminal",
            "args": [
                "--algo", "PPO", 
                "--hparam_file", "${workspaceFolder}/params/PPO_mujoco_debugger.yml", 
                "--envs", "Ant-v5", 
                "--threads", "4",
                "--continous",
                // "--use_wandb",
                "--logging",
                // "--project", "callback-test",
                
            ],
            "justMyCode": false,
        }
    ]
}